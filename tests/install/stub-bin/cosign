#!/bin/sh
# Stub cosign for the installer tests. Logs argv so the test can assert the
# verify was pinned to THIS repo's workflow identity + the GitHub OIDC issuer,
# and by @sha256: digest — not a bare tag.
set -eu

[ -n "${STUB_LOG:-}" ] && printf 'cosign %s\n' "$*" >>"$STUB_LOG"

# An EXECUTABLE but non-functional cosign: wrong arch, missing libc, truncated
# download. The kernel/loader refuses it -> 126 on EVERY verb, `version`
# included. Deliberately a separate knob from STUB_COSIGN_FAIL: that one must
# keep `version` green so the works+fail case still proves the die. Merging them
# would silently move the fail-closed test into the "cannot run" branch.
if [ "${STUB_COSIGN_BROKEN:-0}" = "1" ]; then
    echo "stub: cannot execute binary file: Exec format error" 1>&2
    exit 126
fi

case "${1:-}" in
    verify)
        if [ "${STUB_COSIGN_FAIL:-0}" = "1" ]; then
            echo "Error: no signatures found" 1>&2
            exit 10
        fi
        exit 0
        ;;
    version) echo "stub-cosign 0.0.0"; exit 0 ;;
    *)
        echo "stub: unexpected cosign verb: $*" 1>&2
        exit 64
        ;;
esac
