#!/bin/sh
# Stub container engine for the shim tests. No containers anywhere: it answers
# from a table in $STUB_CONTAINERS and logs every call to $STUB_LOG.
#
# Table format (one entry per whitespace-separated word):
#   <id>;label1=v1;label2=v2;image=IMG
# The stub applies `--filter label=k=v` semantics ITSELF, so a shim that drops
# one of the two labels gets a WRONG answer here — the both-labels contract is
# tested behaviorally, not by log-grepping alone.
set -eu

[ -n "${STUB_LOG:-}" ] && printf '%s %s\n' "$(basename "$0")" "$*" >>"$STUB_LOG"

entry_id() { printf '%s' "$1" | cut -d';' -f1; }

entry_has() {
    # $1 entry, $2 k=v pair
    case ";$(printf '%s' "$1" | cut -d';' -f2-);" in
        *";$2;"*) return 0 ;;
        *) return 1 ;;
    esac
}

entry_field() {
    # $1 entry, $2 field key (image)
    printf '%s' "$1" | tr ';' '\n' | sed -n "s/^$2=//p"
}

cmd="${1:-}"
shift || true

# Containers started by `run -d` within a test persist in $STUB_STATE and are
# merged into `ps` answers — the exec-or-start flow re-discovers after starting.
state_containers() {
    if [ -n "${STUB_STATE:-}" ] && [ -f "$STUB_STATE/containers" ]; then
        cat "$STUB_STATE/containers"
    fi
}

case "$cmd" in
    secret)
        sub="$1"
        shift
        case "$sub" in
            exists) [ -f "${STUB_STATE:?}/secret-$1" ] ;;
            create)
                replace=0
                if [ "$1" = "--replace" ]; then
                    replace=1
                    shift
                fi
                name="$1"
                # real podman refuses a bare create over an existing secret;
                # only --replace overwrites (atomic — the rm+create window is
                # exactly what the shim must never have)
                if [ "$replace" -eq 0 ] && [ -f "${STUB_STATE:?}/secret-$name" ]; then
                    echo "Error: secret name in use: $name" 1>&2
                    exit 125
                fi
                # value arrives on STDIN ('-'), exactly like real podman
                cat >"${STUB_STATE:?}/secret-$name"
                echo "stubsecret-$name"
                ;;
            rm) rm -f "${STUB_STATE:?}/secret-$1" ;;
            ls)
                # Bare names come ONLY with --format '{{.Name}}' — real podman
                # without it prints an ID/NAME/DRIVER table, which would break
                # any caller grepping names; diverging here would hide exactly
                # that bug class.
                if [ "${1:-}" != "--format" ] || [ "${2:-}" != "{{.Name}}" ]; then
                    echo "ID                         NAME        DRIVER      CREATED       UPDATED"
                    exit 0
                fi
                for f in "${STUB_STATE:?}"/secret-*; do
                    [ -f "$f" ] && basename "$f" | sed 's/^secret-//'
                done
                exit 0
                ;;
            *) echo "stub: unexpected secret sub: $sub" 1>&2 && exit 64 ;;
        esac
        exit $?
        ;;
    volume)
        [ "$1" = "exists" ] || { echo "stub: unexpected volume sub: $1" 1>&2; exit 64; }
        [ -f "${STUB_STATE:?}/volume-$2" ]
        exit $?
        ;;
    stop)
        if [ -n "${STUB_STATE:-}" ] && [ -f "$STUB_STATE/containers" ]; then
            grep -v "^$1;" "$STUB_STATE/containers" >"$STUB_STATE/containers.new" || true
            mv "$STUB_STATE/containers.new" "$STUB_STATE/containers"
        fi
        echo "$1"
        exit 0
        ;;
    run)
        detached=0
        volume=""
        labels=""
        for a in "$@"; do
            case "$a" in
                -d) detached=1 ;;
                *:/data) volume="${a%%:*}" ;;
                rustok=* | rustok.agent=*) labels="$labels;$a" ;;
            esac
        done
        # one-shot onboarding: register the volume, print the banner the human
        # must back up (the REAL one prints on the tty; the marker proves the
        # shim let it through untouched)
        case "$*" in
            *create-wallet)
                [ -n "$volume" ] && : >"${STUB_STATE:?}/volume-$volume"
                echo "STUB-SEED-BANNER twelve words here"
                echo "STUB-PIN-BANNER 123456"
                exit 0
                ;;
        esac
        if [ "$detached" -eq 1 ]; then
            id="detached$(tr -dc 'a-f0-9' </dev/urandom 2>/dev/null | head -c 8 || echo cafe0001)"
            [ -n "$volume" ] && : >"${STUB_STATE:?}/volume-$volume"
            echo "$id;${labels#;};volume=$volume;image=stub-img" >>"${STUB_STATE:?}/containers"
            : >"${STUB_STATE:?}/socket-$id"
            echo "$id"
            exit 0
        fi
        echo "stub: unexpected run form: $*" 1>&2
        exit 64
        ;;
    ps)
        if [ "${STUB_PS_FAIL:-0}" = "1" ]; then
            echo "cannot connect to the engine service" 1>&2
            exit 125
        fi
        name_filter=""
        filters=""
        all=0
        while [ $# -gt 0 ]; do
            case "$1" in
                -q | -aq) ;;
                -a) all=1 ;;
                --filter)
                    case "$2" in
                        label=*) filters="$filters ${2#label=}" ;;
                        # volume filter: entries carry a volume=<name> field,
                        # entry_has matches it like any other k=v pair
                        volume=*) filters="$filters $2" ;;
                        name=*) name_filter="${2#name=}" ;;
                    esac
                    shift
                    ;;
            esac
            shift
        done
        # `-aq --filter name=…` — the legacy fixed-name probe.
        if [ -n "$name_filter" ]; then
            [ "$all" -eq 1 ] || true
            printf '%s' "${STUB_LEGACY:-}"
            [ -n "${STUB_LEGACY:-}" ] && echo
            exit 0
        fi
        for entry in ${STUB_CONTAINERS:-} $(state_containers); do
            keep=1
            for f in $filters; do
                entry_has "$entry" "$f" || keep=0
            done
            [ "$keep" -eq 1 ] && entry_id "$entry"
        done
        exit 0
        ;;
    inspect)
        # inspect --format '<tpl>' <id>
        tpl="$2"
        id="$3"
        for entry in ${STUB_CONTAINERS:-} $(state_containers); do
            if [ "$(entry_id "$entry")" = "$id" ]; then
                case "$tpl" in
                    *rustok.agent*)
                        printf '%s' "$entry" | tr ';' '\n' | sed -n 's/^rustok\.agent=//p'
                        exit 0
                        ;;
                    *Config.Image*)
                        entry_field "$entry" image
                        exit 0
                        ;;
                esac
            fi
        done
        echo "no such object: $id" 1>&2
        exit 1
        ;;
    exec)
        # exec [-it|-i] <id> <cmd…> — prove WHICH container was targeted.
        case "$1" in -it | -i) shift ;; esac
        id="$1"
        shift
        # the console's socket-readiness probe (exec <id> test -S <path>)
        if [ "$1" = "test" ]; then
            [ -f "${STUB_STATE:?}/socket-$id" ]
            exit $?
        fi
        echo "EXEC:$id:$1"
        exit 0
        ;;
    info)
        [ "${STUB_INFO_FAIL:-0}" = "1" ] && exit 1
        exit 0
        ;;
    *)
        echo "stub: unexpected engine command: $cmd $*" 1>&2
        exit 64
        ;;
esac
