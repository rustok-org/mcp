#!/bin/sh
# rustok — the wallet's one command.
#
# Surface: `console` (default), `init`, `start`, `stop`, `status`, `doctor`,
# `help`, `version`. The wallet container is agent-launched and has NO fixed
# name (a fixed --name collides with health probes and a second `mcp list` —
# the real production bug this shim exists to bury). Everything here discovers
# it by BOTH labels: `rustok=wallet` and `rustok.agent=<name>`.
#
# Security invariants (the trust boundary of init):
#   - the keyring password is read from /dev/tty only (Rule of two windows:
#     a pipe or an agent shell has no tty and gets a named refusal), travels
#     via a builtin printf into `podman secret create -` stdin or a 0600 file —
#     NEVER through an engine argv, an env-file or a config;
#   - the seed + PIN print happens inside `create-wallet` on the INHERITED tty —
#     the shim never captures, logs or re-echoes that output;
#   - `init` NEVER deletes a keystore volume; --force re-stores the SECRET only.
#
# POSIX sh on purpose (see epic decision #3): no arrays, no bashisms.
set -eu

VERSION="0.3.0"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rustok"
CONFIG_FILE="$CONFIG_DIR/config"
# The shipped wallet image; RUSTOK_IMAGE overrides (a digest-pinned ref comes
# with the installer stage of the epic).
DEFAULT_IMAGE="ghcr.io/rustok-org/rustok-wallet-tui:v0.8.1"

usage() {
    cat <<'EOF'
rustok — self-custody wallet helper

Usage: rustok [command] [--agent <name>] [--force]

Commands:
  console        open the human approval console (default when no command);
                 starts the wallet first if an initialized one is not running
  init           create a NEW wallet for an agent (interactive; prints the
                 12-word phrase and approval PIN exactly once — run it in your
                 own terminal, never through an agent)
  connect        register the wallet as an MCP server with an agent client:
                 rustok connect claude|cursor|hermes (the wallet defaults to
                 that client's own — --agent overrides); claude/cursor need
                 jq, hermes needs python3+PyYAML; --force replaces an
                 existing registration
  start          start the wallet container in the background
  stop           stop the running wallet container
  status         show the running wallet container(s)
  doctor         diagnose the setup (engine, config, PATH, leftovers)
  update         pull the current wallet image and re-register every rustok
                 MCP entry (each client keeps its own wallet, read from the
                 entry itself; the old entry is printed before replacing);
                 the shim itself does not self-update — re-run the installer
  uninstall      data-safe teardown: deregister from agents, stop wallets,
                 remove secrets, the installer PATH block and the shim.
                 Keystore volumes (your keys) are NEVER touched without
                 --purge-keys and its interactive confirmation
  help           show this help
  version        show the shim version

Options:
  --agent <name>   the agent this wallet belongs to (default: claude)
  --force          init: re-store the keyring password secret when it already
                   exists (the keystore volume is never touched);
                   connect: replace an existing MCP registration
  --purge-keys     uninstall only: ALSO delete the keystore volumes after an
                   interactive confirmation on your terminal — this destroys
                   the keys; without your seed phrase backup the funds are
                   unrecoverable

Environment:
  RUSTOK_IMAGE       wallet image override
  RUSTOK_RPC_URLS_*  chain RPC URLs. `connect` stores each one as a per-agent
                     podman secret (rustok-rpc-<agent>-<chain>) and both the
                     registration and `start` deliver through that secret —
                     a keyed URL stays out of argv, agent configs and
                     `podman inspect`. Other RUSTOK_* config is frozen into
                     the registration as literal values at connect time.
EOF
}

die() {
    echo "rustok: $*" 1>&2
    exit 1
}

# --- engine ------------------------------------------------------------------
# Deterministic and STICKY (epic М-3): first resolution (podman preferred,
# docker fallback) is written to the config and never silently re-chosen —
# wallet volumes live per-engine, so a quiet switch would "lose" the wallet.

resolve_engine() {
    engine=""
    if [ -f "$CONFIG_FILE" ]; then
        engine="$(sed -n 's/^engine=//p' "$CONFIG_FILE" | head -n 1)"
    fi
    if [ -n "$engine" ]; then
        case "$engine" in
            podman | docker) ;;
            *) die "configured engine '$engine' in $CONFIG_FILE is not podman or docker — edit the config" ;;
        esac
        command -v "$engine" >/dev/null 2>&1 || die \
            "configured engine '$engine' ($CONFIG_FILE) is not installed — reinstall it, or edit the config (a wallet volume does not move between engines)"
        return 0
    fi
    if command -v podman >/dev/null 2>&1; then
        engine="podman"
    elif command -v docker >/dev/null 2>&1; then
        engine="docker"
    else
        die "neither podman nor docker found — install podman (recommended): https://podman.io/getting-started/installation"
    fi
    mkdir -p "$CONFIG_DIR"
    printf 'engine=%s\n' "$engine" >"$CONFIG_FILE"
}

# --- discovery ---------------------------------------------------------------
# ALWAYS both labels. `--filter label=rustok=wallet` alone would match another
# agent's wallet; `rustok.agent` alone would match a non-wallet container.

discover_ids() {
    # $1: agent name or "" for any agent. An installed-but-dead engine must be
    # a named error here too, not a raw `ps` stderr (doctor already says it
    # nicely — console/status deserve the same).
    if [ -n "$1" ]; then
        "$engine" ps -q --filter label=rustok=wallet --filter "label=rustok.agent=$1" \
            || die "'$engine' failed listing containers — is the service running? (try: rustok doctor)"
    else
        "$engine" ps -q --filter label=rustok=wallet \
            || die "'$engine' failed listing containers — is the service running? (try: rustok doctor)"
    fi
}

agent_of() {
    # `inspect … index .Config.Labels` is the one label accessor both engines
    # implement identically (ps --format templates differ between them).
    # Pre-label wallets (older launch configs) carry no rustok.agent at all —
    # they are real and must show up readably, not as an empty string.
    name="$("$engine" inspect --format '{{ index .Config.Labels "rustok.agent" }}' "$1" 2>/dev/null || true)"
    if [ -n "$name" ]; then
        printf '%s\n' "$name"
    else
        echo "(unlabeled)"
    fi
}

agent_list() {
    # Sorted, comma-separated agent names of every running wallet — the loud
    # N>1 refusal must NAME the choices, never pick the first match.
    # (awk, not `paste -d ', '`: paste CYCLES multi-char delimiter lists.)
    for id in "$@"; do
        agent_of "$id"
    done | LC_ALL=C sort | awk 'NR > 1 { printf ", " } { printf "%s", $0 } END { print "" }'
}

# --- per-agent naming ----------------------------------------------------------

volume_for() {
    # claude keeps the historical volume name every doc and existing user has;
    # any other agent gets its own per-agent volume (epic decision #4).
    if [ "$1" = "claude" ]; then
        echo "rustok-wallet-tui"
    else
        echo "rustok-$1"
    fi
}

secret_for() { echo "rustok-keyring-$1"; }
password_file_for() { echo "$CONFIG_DIR/keyring-pass-$1"; }

valid_agent_name() {
    # ONE charset gate for every road an agent name travels in on: the --agent
    # option AND the rustok.agent label `update` reads back out of a client
    # config. The name becomes a container label, a volume name and (unquoted)
    # a run-argv token — anything outside this set could inject flags/args
    # into `podman run`. (Threat model: pasted untrusted commands / a hand-
    # edited registration.)
    case "$1" in
        [a-zA-Z0-9]*[!a-zA-Z0-9_-]* | [!a-zA-Z0-9]* | "") return 1 ;;
    esac
    return 0
}

image_ref() { echo "${RUSTOK_IMAGE:-$DEFAULT_IMAGE}"; }

secret_present() {
    # podman: the secret store; docker (no store without swarm): the 0600 file.
    if [ "$engine" = "podman" ]; then
        "$engine" secret exists "$(secret_for "$1")"
    else
        [ -f "$(password_file_for "$1")" ]
    fi
}

password_args_for() {
    # The engine-run fragment delivering the password — value never in argv.
    if [ "$engine" = "podman" ]; then
        echo "--secret $(secret_for "$1"),type=env,target=RUSTOK_KEYRING_PASSWORD"
    else
        echo "-v $(password_file_for "$1"):/run/keyring-pass:ro -e RUSTOK_KEYRING_PASSWORD_FILE=/run/keyring-pass"
    fi
}

rustok_env_names() {
    # RUSTOK_* config vars forwarded to `start` BY NAME (`-e NAME` inherits the
    # value engine-side — values stay out of argv AND out of shell history).
    # The keyring password is deliberately excluded: it travels only as a
    # secret/_FILE, and a stray env var would win over the stored secret and
    # cause mismatched-unlock mysteries. RUSTOK_IMAGE is the shim's own knob.
    # Sorted so every argv built from this list is deterministic.
    env | sed -n 's/^\(RUSTOK_[A-Z0-9_]*\)=.*/\1/p' \
        | grep -v -E '^RUSTOK_(KEYRING_PASSWORD(_FILE)?|IMAGE)$' | LC_ALL=C sort || true
}

rpc_env_names() {
    # The RPC subset of the environment — each one is a second-class secret
    # (provider key in the URL) and gets its own per-agent podman secret.
    env | sed -n 's/^\(RUSTOK_RPC_URLS_[A-Z0-9_]*\)=.*/\1/p' | LC_ALL=C sort || true
}

rpc_secret_names() {
    # Existing per-agent RPC secrets (podman store only; docker has no store —
    # its RPC rides as an honest literal -e, the documented second tier).
    # ANCHORED both ways: a bare prefix grep would let agent 'claude' swallow
    # 'rustok-rpc-claude-backup-1' (agent claude-backup's provider key — a
    # cross-agent leak); chain suffixes are [A-Z0-9_] by construction
    # (rpc_env_names), so the tail anchor rejects any hyphenated agent name.
    [ "$engine" = "podman" ] || return 0
    # Engine status is checked SEPARATELY from the grep: in one pipeline the
    # exit status belongs to sort (0 on empty input), so a dead secret store
    # would silently read as "no secrets" — and on podman the RPC URL rides
    # ONLY this channel, so the caller would go on without RPC at all.
    rpc_ls_out="$("$engine" secret ls --format '{{.Name}}' 2>/dev/null)" \
        || die "'$engine' failed listing secrets — is the service running? (try: rustok doctor)"
    printf '%s\n' "$rpc_ls_out" | grep -E "^rustok-rpc-$1-[A-Z0-9_]+$" | LC_ALL=C sort || true
}

label_volume_args() {
    # Shared header of the agent-run argv (registration AND detached start) —
    # kept in ONE place: label drift is a proven production bug class (the
    # live pre-label containers are invisible to two-label discovery today).
    # Safe as a word-split fragment: the agent passed the charset gate and
    # the volume name is ours — no arbitrary values (unlike the -e NAME=value
    # loop, which MUST stay inline at its call sites).
    echo "--label rustok=wallet --label rustok.agent=$1 -v $(volume_for "$1"):/data"
}

rpc_secret_args() {
    # stdin: anchored secret names, one per line ($1: agent); emits the
    # --secret fragment both argv builders splice in verbatim.
    while IFS= read -r rpc_secret; do
        [ -n "$rpc_secret" ] || continue
        printf ' --secret %s,type=env,target=RUSTOK_RPC_URLS_%s' \
            "$rpc_secret" "${rpc_secret#rustok-rpc-"$1"-}"
    done
}

store_rpc_secrets() {
    # Every RUSTOK_RPC_URLS_<chain> in the environment becomes the per-agent
    # secret rustok-rpc-<agent>-<chain>. Atomic --replace ONLY: `secret rm`
    # succeeds silently even on a held secret, leaving a no-secret window a
    # crashed caller would freeze forever. podman-only (see rpc_secret_names).
    [ "$engine" = "podman" ] || return 0
    for name in $(rpc_env_names); do
        rpc_secret="rustok-rpc-$1-${name#RUSTOK_RPC_URLS_}"
        # the name matched ^RUSTOK_RPC_URLS_[A-Z0-9_]*$ — eval is closed;
        # a builtin printf into stdin keeps the value out of every argv
        eval "rpc_value=\${$name}"
        printf '%s' "$rpc_value" | "$engine" secret create --replace "$rpc_secret" - >/dev/null
        rpc_value=""
        echo "rustok: RPC secret '$rpc_secret' stored ($name)"
    done
}

# --- commands ----------------------------------------------------------------

read_password_twice() {
    # The gate: stdin must BE a terminal (a pipe or an agent shell fails
    # `-t 0` deterministically — some agent sandboxes still carry a readable
    # /dev/tty, so probing /dev/tty alone is not a reliable refusal). Then the
    # password is read from /dev/tty itself, immune to later redirections
    # (Rule of two windows).
    if [ ! -t 0 ]; then
        die "init needs your own terminal — never run it through an agent or a pipe: the recovery phrase would leak into its context"
    fi
    if ! { exec 3</dev/tty; } 2>/dev/null; then
        die "init needs your own terminal (no /dev/tty here) — never run it through an agent or a pipe: the recovery phrase would leak into its context"
    fi
    # Restore echo (and drop the password) on Ctrl-C / kill during entry —
    # otherwise the terminal is left with echo off.
    trap 'stty echo </dev/tty 2>/dev/null || true; PW="" PW2=""; exit 130' INT TERM HUP
    printf 'Keyring password (unlocks the keystore): ' >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    IFS= read -r PW <&3 || PW=""
    stty echo </dev/tty 2>/dev/null || true
    printf '\n' >/dev/tty
    printf 'Repeat the password: ' >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    IFS= read -r PW2 <&3 || PW2=""
    stty echo </dev/tty 2>/dev/null || true
    printf '\n' >/dev/tty
    trap - INT TERM HUP
    exec 3<&-
    [ -n "$PW" ] || die "empty password — nothing stored"
    [ "$PW" = "$PW2" ] || die "passwords do not match — nothing stored"
}

store_password() {
    # printf is a shell BUILTIN in every /bin/sh we target (dash/bash/ash):
    # the password never becomes a process argv.
    if [ "$engine" = "podman" ]; then
        printf '%s' "$PW" | "$engine" secret create "$(secret_for "$1")" - >/dev/null
    else
        umask 077
        mkdir -p "$CONFIG_DIR"
        printf '%s' "$PW" >"$(password_file_for "$1")"
    fi
}

remove_stored_password() {
    if [ "$engine" = "podman" ]; then
        "$engine" secret rm "$(secret_for "$1")" >/dev/null
    else
        rm -f "$(password_file_for "$1")"
    fi
}

cmd_init() {
    agent="${AGENT:-claude}"
    volume="$(volume_for "$agent")"

    volume_exists=0
    "$engine" volume exists "$volume" 2>/dev/null && volume_exists=1

    if [ "$volume_exists" -eq 1 ] && [ "$FORCE" -eq 0 ]; then
        die "wallet volume '$volume' already exists — init creates NEW wallets and never touches keystores. To re-store a changed keyring password: rustok init --force (secret only; your keys stay put)"
    fi
    if secret_present "$agent" && [ "$FORCE" -eq 0 ]; then
        die "a stored keyring password for agent '$agent' already exists — rerun with --force to replace it (the keystore volume is never touched)"
    fi

    read_password_twice
    if secret_present "$agent"; then
        remove_stored_password "$agent"
    fi
    store_password "$agent"
    PW="" PW2=""
    echo "rustok: keyring password stored for agent '$agent' ($engine)"

    if [ "$volume_exists" -eq 1 ]; then
        echo "rustok: keystore volume '$volume' already present — password re-stored, wallet untouched"
        return 0
    fi

    # Onboarding prints the 12 words + PIN ONCE, on the inherited tty — the
    # shim adds no capture, no tee, no log around it.
    echo "rustok: creating the wallet — back up the 12 words and the PIN it prints:"
    # shellcheck disable=SC2046  # password_args_for emits a word-split fragment
    "$engine" run -it --rm \
        -v "$volume:/data" \
        $(password_args_for "$agent") \
        "$(image_ref)" create-wallet
    echo "rustok: wallet created for agent '$agent' — next: rustok start (or connect your agent), then fund the address"
}

wallet_run_args() {
    # The detached labeled run — shared by `start` and console auto-start.
    # NEVER --name: labels only (that is the whole point of the label model).
    agent="$1"
    volume="$(volume_for "$agent")"
    rpc_secrets="$(rpc_secret_names "$agent")"
    # shellcheck disable=SC2046  # label_volume_args emits a word-split fragment
    set -- run -d -i --rm --init $(label_volume_args "$agent")
    for name in $(rustok_env_names); do
        case "$name" in
            RUSTOK_RPC_URLS_*)
                # a `connect`-created secret owns this URL — the env
                # name-forward stays only for pre-connect setups
                if printf '%s\n' "$rpc_secrets" \
                    | grep -qx "rustok-rpc-$agent-${name#RUSTOK_RPC_URLS_}"; then
                    continue
                fi
                ;;
        esac
        set -- "$@" -e "$name"
    done
    # shellcheck disable=SC2046
    set -- "$@" $(printf '%s\n' "$rpc_secrets" | rpc_secret_args "$agent")
    # shellcheck disable=SC2046
    set -- "$@" $(password_args_for "$agent") "$(image_ref)"
    printf '%s\n' "$@"
}

start_wallet_detached() {
    agent="$1"
    secret_present "$agent" || die "no stored keyring password for agent '$agent' — run: rustok init"
    "$engine" volume exists "$(volume_for "$agent")" 2>/dev/null \
        || die "no wallet volume '$(volume_for "$agent")' — run: rustok init"
    # Rebuild argv from the newline list (values never contain newlines here:
    # names/labels/volumes are ours, the password rides the secret store).
    set --
    while IFS= read -r arg; do
        set -- "$@" "$arg"
    done <<EOF
$(wallet_run_args "$agent")
EOF
    "$engine" "$@" >/dev/null
    echo "rustok: wallet for agent '$agent' starting in the background"
}

cmd_start() {
    agent="${AGENT:-claude}"
    ids="$(discover_ids "$agent")"
    if [ -n "$ids" ]; then
        die "wallet for agent '$agent' is already running (see: rustok status)"
    fi
    start_wallet_detached "$agent"
}

cmd_stop() {
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086
    set -- $ids
    case $# in
        0)
            echo "rustok: nothing to stop"
            ;;
        1)
            "$engine" stop "$1" >/dev/null
            echo "rustok: wallet stopped"
            ;;
        *)
            die "multiple wallets running: $(agent_list "$@") — use --agent <name>"
            ;;
    esac
}

cmd_console() {
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086  # word-splitting the id list is the point
    set -- $ids
    case $# in
        0)
            # exec-or-start (epic pain #6): an initialized wallet is started
            # here and now; an uninitialized one gets pointed at init.
            agent="${AGENT:-claude}"
            if ! secret_present "$agent" 2>/dev/null; then
                if [ -n "$AGENT" ]; then
                    die "no wallet running for agent '$AGENT' — start that agent's session first (check: rustok status)"
                fi
                die "no wallet running — the agent session starts it; check: rustok status (new here? rustok init)"
            fi
            start_wallet_detached "$agent"
            # The console needs the approver socket, which core creates during
            # startup — poll briefly instead of failing into a raw error.
            tries=0
            while ! "$engine" exec "$(discover_ids "$agent")" test -S /run/wallet/approve.sock 2>/dev/null; do
                tries=$((tries + 1))
                [ "$tries" -gt 30 ] && die "wallet started but the approval socket never appeared — check: rustok status / $engine logs"
                sleep 1
            done
            exec "$engine" exec -it "$(discover_ids "$agent")" rustok-console
            ;;
        1)
            exec "$engine" exec -it "$1" rustok-console
            ;;
        *)
            list="$(agent_list "$@")"
            echo "rustok: multiple wallets running: $list — use --agent <name>" 1>&2
            case "$list" in
                *"(unlabeled)"*)
                    echo "rustok: hint: an '(unlabeled)' wallet predates the label model — add --label rustok.agent=<name> to its launch config (see docs/INSTALL.md)" 1>&2
                    ;;
            esac
            exit 1
            ;;
    esac
}

cmd_connect() {
    # Registration probes READ the client's config file: `claude mcp get`/`list`
    # both health-check, i.e. START a wallet container on the shared keystore
    # just to answer "am I registered?". User-scope only, by design — the shim
    # manages exactly what it writes and never touches other scopes. The wallet
    # defaults to the CLIENT's own (epic decision #4: every agent gets its own
    # keystore; sharing one is the unverified multi-writer class).
    client="${CONNECT_TARGET:-claude}"
    agent="${AGENT:-$client}"
    volume="$(volume_for "$agent")"

    case "$client" in
        claude | cursor)
            command -v jq >/dev/null 2>&1 \
                || die "connect needs jq to read the agent config safely — install it (dnf/apt install jq); no other rustok command uses it"
            ;;
        hermes)
            if ! command -v python3 >/dev/null 2>&1 || ! python3 -c 'import yaml' 2>/dev/null; then
                die "connect hermes needs python3 with PyYAML (Hermes itself ships both) — install python3 + PyYAML"
            fi
            ;;
    esac
    cfg="$(client_cfg_for "$client")"

    # Differentiated init preflight: a volume without a stored secret is the
    # env-file era — the exact live state Blocker-1 found; a blank machine
    # just needs init.
    if ! secret_present "$agent" 2>/dev/null; then
        if "$engine" volume exists "$volume" 2>/dev/null; then
            die "wallet volume '$volume' exists but no keyring password is stored — an env-file-era setup. Migrate: rustok init --force (re-enter your password; your keys stay put), then: rustok connect $client --force"
        fi
        die "no wallet for agent '$agent' yet — run: rustok init"
    fi
    "$engine" volume exists "$volume" 2>/dev/null \
        || die "no wallet volume '$volume' — run: rustok init"

    # Existence probe. claude/cursor: full jq -e contract — 0 = registered;
    # 1 = no entry and 2 = no config file yet, both FREE (a fresh machine is
    # who this epic is for); anything else = an unreadable config we refuse
    # to write over. hermes: same contract via python (an ABSENT config is a
    # missing Hermes install, not a fresh state — its config ships with it).
    registered=1
    case "$client" in
        claude | cursor)
            registered=0
            jq -e '.mcpServers.rustok' "$cfg" >/dev/null 2>&1 || registered=$?
            case "$registered" in
                0)
                    [ "$FORCE" -eq 1 ] || die "MCP server 'rustok' is already registered — rerun with --force to replace the registration (RPC secrets refresh either way)"
                    if [ "$client" = "claude" ] && jq -e '.mcpServers.rustok.args | index("--env-file")' "$cfg" >/dev/null 2>&1; then
                        echo "rustok: replacing an --env-file registration — the plaintext env file itself is NOT deleted; remove it after the new setup is verified" 1>&2
                    fi
                    ;;
                1 | 2) registered=1 ;;
                *) die "cannot read $cfg (jq exit $registered — broken JSON?) — fix the agent config by hand; connect refuses to write over it" ;;
            esac
            if [ "$client" = "claude" ] && jq -e '.mcpServers."rustok-wallet-tui"' "$cfg" >/dev/null 2>&1; then
                echo "rustok: warn: a doc-era 'rustok-wallet-tui' entry is also registered — remove it: claude mcp remove -s user rustok-wallet-tui" 1>&2
            fi
            ;;
        hermes)
            [ -f "$cfg" ] || die "no Hermes config at $cfg — is Hermes installed?"
            hrc=0
            python3 - "$cfg" <<'PYEOF' || hrc=$?
import sys
import yaml
try:
    cfg = yaml.safe_load(open(sys.argv[1]))
    if not isinstance(cfg, dict):
        raise ValueError("top level is not a mapping")
except Exception as exc:
    print("unreadable YAML: %s" % exc, file=sys.stderr)
    sys.exit(3)
servers = cfg.get("mcp_servers")
sys.exit(0 if isinstance(servers, dict) and "rustok" in servers else 1)
PYEOF
            case "$hrc" in
                0)
                    registered=0
                    [ "$FORCE" -eq 1 ] || die "MCP server 'rustok' is already registered — rerun with --force to replace the registration (RPC secrets refresh either way)"
                    ;;
                1) registered=1 ;;
                *) die "unreadable YAML in $cfg — fix the Hermes config by hand; connect refuses to write over it" ;;
            esac
            ;;
    esac

    # Multiplicity is born from agent SESSIONS (each one starts a container),
    # and live pre-label containers carry no rustok.agent — so the honest
    # domain is the VOLUME, not the label pair.
    nrun=0
    for id in $("$engine" ps -q --filter "volume=$volume" 2>/dev/null || true); do
        nrun=$((nrun + 1))
    done
    if [ "$nrun" -gt 0 ]; then
        echo "rustok: warn: $nrun container(s) already use keystore volume '$volume' (each agent session starts one); concurrent writers on one keystore are UNVERIFIED — close extra sessions before starting new ones" 1>&2
    fi

    # RPC secrets FIRST, registration second: a failure between the two
    # leaves the old registration working.
    store_rpc_secrets "$agent"

    # The engine-run argv TAIL — one build for every client transport.
    # The header/password/rpc segments come from the same fragment helpers
    # the start path uses (no drift); ONLY the -e NAME=value loop stays
    # inline, because it alone carries arbitrary values a line-based
    # hand-off could not survive.
    reg_rpc_secrets="$(rpc_secret_names "$agent")"
    # shellcheck disable=SC2046  # fragment helpers emit word-split args
    set -- run -i --rm --init \
        $(label_volume_args "$agent") $(password_args_for "$agent") \
        $(printf '%s\n' "$reg_rpc_secrets" | rpc_secret_args "$agent")
    # Non-secret RUSTOK_* config is FROZEN as literal -e values: the agent
    # client launches this command from ITS environment, not your shell —
    # a name-only -e would inherit nothing. Change a value → re-run connect.
    tier_note=0
    for name in $(rustok_env_names); do
        case "$name" in
            RUSTOK_RPC_URLS_*)
                if [ "$engine" = "podman" ]; then
                    continue # rides the secret built above
                fi
                tier_note=1 # docker: honest bare -e, the documented second tier
                ;;
        esac
        eval "env_value=\${$name}"
        set -- "$@" -e "$name=$env_value"
        env_value=""
    done
    set -- "$@" "$(image_ref)"
    if [ "$tier_note" -eq 1 ]; then
        echo "rustok: note: docker fallback — RPC URLs ride as plain -e in the agent config (second tier; podman delivers them as secrets)" 1>&2
    fi

    case "$client" in
        claude) connect_write_claude "$@" ;;
        cursor) connect_write_cursor "$@" ;;
        hermes) connect_write_hermes "$@" ;;
    esac
}

connect_write_claude() {
    # Transport: the claude CLI owns the write; "$@" is the engine-run tail.
    old_entry=""
    if [ "$registered" -eq 0 ]; then
        # Snapshot BEFORE remove: `claude mcp add` has no replace flag, so
        # remove→add is forced — and a failed add would otherwise leave the
        # wallet silently unregistered with no way back but memory.
        old_entry="$(jq -c '.mcpServers.rustok' "$cfg" 2>/dev/null || true)"
        if [ -n "$old_entry" ] && [ "$old_entry" != "null" ]; then
            # Print it on the SUCCESSFUL replace path too, not only on a
            # failed add: `update` replaces routinely, and a hand-tuned entry
            # must never vanish silently (one recovery path in all three
            # writers — Gate-1 2.3c).
            echo "rustok: replacing the previous entry (return path if needed):" 1>&2
            printf '  %s\n' "$old_entry" 1>&2
        fi
        claude mcp remove -s user rustok >/dev/null \
            || die "claude mcp remove failed — registration left unchanged"
    fi
    set -- mcp add -s user rustok -- "$engine" "$@"
    if ! claude "$@"; then
        if [ -n "$old_entry" ] && [ "$old_entry" != "null" ]; then
            echo "rustok: 'claude mcp add' failed AND the old registration is already removed — the wallet is currently NOT registered" 1>&2
            echo "rustok: previous entry (restore by hand under .mcpServers.rustok in $cfg):" 1>&2
            printf '  %s\n' "$old_entry" 1>&2
            echo "rustok: or re-run it manually:" 1>&2
        else
            echo "rustok: 'claude mcp add' failed — re-run it manually:" 1>&2
        fi
        printf '  claude' 1>&2
        for arg in "$@"; do printf ' %s' "$arg" 1>&2; done
        printf '\n' 1>&2
        exit 1
    fi
    echo "rustok: MCP server 'rustok' registered for agent '$agent' ($engine) — restart the agent session to pick it up"
}

connect_write_cursor() {
    # No registrar CLI exists for Cursor — the shim owns the file write:
    # print the old entry as the return path, then ONE atomic tmp+mv (the
    # previous registration stays valid until the very rename — no
    # unregistered window at any point).
    if [ "$registered" -eq 0 ]; then
        echo "rustok: replacing the previous entry (return path if needed):" 1>&2
        printf '  %s\n' "$(jq -c '.mcpServers.rustok' "$cfg" 2>/dev/null || true)" 1>&2
    fi
    mkdir -p "${cfg%/*}" 2>/dev/null || true
    if [ ! -f "$cfg" ]; then
        printf '{}\n' >"$cfg" 2>/dev/null \
            || die "could not update $cfg — is the directory writable? (nothing was changed)"
    fi
    cursor_tmp="$cfg.rustok-tmp"
    if ! jq --arg cmd "$engine" \
        '.mcpServers.rustok = {command: $cmd, args: $ARGS.positional}' \
        --args -- "$@" <"$cfg" >"$cursor_tmp" 2>/dev/null; then
        rm -f "$cursor_tmp"
        die "could not update $cfg (write failed) — the existing config is untouched"
    fi
    mv "$cursor_tmp" "$cfg" \
        || die "could not update $cfg (rename failed) — the existing config is untouched"
    echo "rustok: MCP server 'rustok' registered for Cursor, agent '$agent' ($engine) — reload Cursor to pick it up"
}

connect_write_hermes() {
    # No registrar CLI for Hermes either. Plain YAML round-trip (ratified:
    # comments are not preserved) — backup FIRST, then one atomic tmp+mv;
    # any failure leaves the live config untouched.
    hermes_backup="$cfg.rustok-bak-$(date +%Y%m%d-%H%M%S)"
    cp "$cfg" "$hermes_backup" 2>/dev/null \
        || die "cannot write backup next to $cfg — is the directory writable? (nothing was changed)"
    hermes_note="$(python3 - "$cfg" "$engine" "$@" <<'PYEOF'
import os
import sys
import tempfile
import yaml
cfg_path, engine = sys.argv[1], sys.argv[2]
args = sys.argv[3:]
try:
    with open(cfg_path) as f:
        cfg = yaml.safe_load(f) or {}
    if not isinstance(cfg, dict):
        raise ValueError("top level is not a mapping")
except Exception as exc:
    print("unreadable YAML: %s" % exc, file=sys.stderr)
    sys.exit(3)
servers = cfg.get("mcp_servers")
if not isinstance(servers, dict):
    servers = {}
old = servers.get("rustok")
if old is not None:
    # One recovery path across all three writers (Gate-1 2.3c): the replaced
    # entry is printed, never swallowed — the backup file holds it too, but
    # a routine `update` must SAY that something was overwritten.
    sys.stderr.write("rustok: replacing the previous entry (return path if needed):\n")
    for line in yaml.safe_dump(
            {"rustok": old}, sort_keys=False, allow_unicode=True).splitlines():
        sys.stderr.write("  %s\n" % line)
dropped = "rustok-wallet" in servers
servers.pop("rustok-wallet", None)
servers["rustok"] = {"command": engine, "args": list(args), "enabled": True}
cfg["mcp_servers"] = servers
try:
    fd, tmp = tempfile.mkstemp(
        dir=os.path.dirname(os.path.abspath(cfg_path)), prefix=".rustok-tmp-")
    with os.fdopen(fd, "w") as f:
        yaml.safe_dump(cfg, f, sort_keys=False, allow_unicode=True)
    os.replace(tmp, cfg_path)
except Exception as exc:
    print("write failed: %s" % exc, file=sys.stderr)
    sys.exit(4)
print("DROPPED" if dropped else "CLEAN")
PYEOF
)" || die "could not update $cfg — backup untouched at $hermes_backup"
    if [ "$hermes_note" = "DROPPED" ]; then
        echo "rustok: note: legacy 'rustok-wallet' entry (Stage-0 era) replaced by 'rustok'" 1>&2
    fi
    if [ -f "$HOME/.hermes/scripts/rustok-mcp-server.py" ]; then
        echo "rustok: hint: the Stage-0 wrapper is no longer used — remove it: rm ~/.hermes/scripts/rustok-mcp-server.py" 1>&2
    fi
    echo "rustok: MCP server 'rustok' registered for Hermes, agent '$agent' ($engine, enabled: true) — restart Hermes to pick it up"
}

cmd_status() {
    echo "engine: $engine ($CONFIG_FILE)"
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -eq 0 ]; then
        echo "no wallet running — the agent session starts it"
        return 0
    fi
    printf '%-12s %-14s %s\n' "AGENT" "CONTAINER" "IMAGE"
    for id in "$@"; do
        image="$("$engine" inspect --format '{{.Config.Image}}' "$id" 2>/dev/null || echo '?')"
        printf '%-12s %-14s %s\n' "$(agent_of "$id")" "$(printf '%.12s' "$id")" "$image"
    done
}

cmd_doctor() {
    failed=0
    # resolve_engine has already pinned the choice by the time we are here.
    echo "ok: engine '$engine' (pinned in $CONFIG_FILE)"
    if ! "$engine" info >/dev/null 2>&1; then
        echo "fail: '$engine' is installed but not usable — is the service/machine running?"
        failed=1
    else
        echo "ok: $engine is responding"
    fi
    # PATH sanity for the shim install dir.
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) echo "ok: ~/.local/bin is on PATH" ;;
        *) echo "warn: ~/.local/bin is NOT on PATH — the installer puts rustok there; add it to your shell profile" ;;
    esac
    if command -v jq >/dev/null 2>&1; then
        echo "ok: jq present (used only by 'rustok connect')"
    else
        echo "info: jq not found — needed only by 'rustok connect' (dnf/apt install jq)"
    fi
    if command -v python3 >/dev/null 2>&1 && python3 -c 'import yaml' 2>/dev/null; then
        echo "ok: python3+PyYAML present (used only by 'rustok connect hermes')"
    else
        echo "info: python3+PyYAML not found — needed only by 'rustok connect hermes'"
    fi
    # Running wallets.
    ids="$(discover_ids "")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -eq 0 ]; then
        echo "info: no wallet running (the agent session starts it)"
    else
        echo "ok: $# wallet(s) running: $(agent_list "$@")"
        unlabeled=0
        for id in "$@"; do
            if [ "$(agent_of "$id")" = "(unlabeled)" ]; then
                unlabeled=$((unlabeled + 1))
            fi
        done
        if [ "$unlabeled" -gt 0 ]; then
            echo "warn: $unlabeled wallet(s) without a rustok.agent label (pre-label config) — add --label rustok.agent=<name> (see docs/INSTALL.md)"
        fi
    fi
    # The legacy fixed-name container the label model replaced.
    legacy="$("$engine" ps -aq --filter name=rustok-wallet-tui 2>/dev/null || true)"
    if [ -n "$legacy" ]; then
        echo "warn: leftover fixed-name container 'rustok-wallet-tui' from an old setup — remove it: $engine rm -f rustok-wallet-tui"
    fi
    return "$failed"
}

client_cfg_for() {
    # The one map from a client name to its MCP config file — connect, update
    # and uninstall must never disagree on where a registration lives.
    case "$1" in
        claude) echo "$HOME/.claude.json" ;;
        cursor) echo "$HOME/.cursor/mcp.json" ;;
        hermes) echo "$HOME/.hermes/config.yaml" ;;
    esac
}

cmd_update() {
    # Pull FIRST: a broken pull must stop the run before any registration is
    # touched — a half-updated set of agent configs is worse than a stale one.
    "$engine" pull "$(image_ref)" >/dev/null \
        || die "image pull failed — no registration was touched (network? registry? try: rustok doctor)"
    ids="$(discover_ids "")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -gt 0 ]; then
        echo "rustok: note: $# running wallet(s) ($(agent_list "$@")) keep the previous image until their agent's next session start (or: rustok stop)" 1>&2
    fi
    updated=0
    upd_failed=0
    for upd_client in claude cursor hermes; do
        upd_cfg="$(client_cfg_for "$upd_client")"
        [ -f "$upd_cfg" ] || continue
        upd_agent=""
        upd_probe=""
        case "$upd_client" in
            claude | cursor)
                if ! command -v jq >/dev/null 2>&1; then
                    echo "rustok: warn: cannot probe $upd_cfg without jq — skipped (install jq and re-run)" 1>&2
                    continue
                fi
                jq -e '.mcpServers.rustok' "$upd_cfg" >/dev/null 2>&1 || continue
                upd_agent="$(jq -r '.mcpServers.rustok.args // [] | map(select(type == "string" and startswith("rustok.agent="))) | first // empty' "$upd_cfg" 2>/dev/null | sed 's/^rustok\.agent=//')"
                ;;
            hermes)
                if ! command -v python3 >/dev/null 2>&1 || ! python3 -c 'import yaml' 2>/dev/null; then
                    echo "rustok: warn: cannot probe $upd_cfg without python3+PyYAML — skipped" 1>&2
                    continue
                fi
                upd_probe="$(python3 - "$upd_cfg" <<'PYEOF'
import sys
import yaml
try:
    cfg = yaml.safe_load(open(sys.argv[1]))
    if not isinstance(cfg, dict):
        raise ValueError("top level is not a mapping")
except Exception:
    print("UNREADABLE")
    sys.exit(0)
servers = cfg.get("mcp_servers")
entry = servers.get("rustok") if isinstance(servers, dict) else None
if not isinstance(entry, dict):
    print("ABSENT")
    sys.exit(0)
for arg in entry.get("args") or []:
    if isinstance(arg, str) and arg.startswith("rustok.agent="):
        print("AGENT %s" % arg.split("=", 1)[1])
        sys.exit(0)
print("NOAGENT")
PYEOF
)"
                case "$upd_probe" in
                    ABSENT) continue ;;
                    "AGENT "*) upd_agent="${upd_probe#AGENT }" ;;
                    UNREADABLE)
                        echo "rustok: $upd_client: unreadable YAML in $upd_cfg — fix it by hand, then: rustok connect hermes --force" 1>&2
                        upd_failed=$((upd_failed + 1))
                        continue
                        ;;
                esac
                ;;
        esac
        if [ -z "$upd_agent" ]; then
            echo "rustok: $upd_client: registration found but no rustok.agent label inside it — re-run: rustok connect $upd_client --force" 1>&2
            upd_failed=$((upd_failed + 1))
            continue
        fi
        if ! valid_agent_name "$upd_agent"; then
            echo "rustok: $upd_client: invalid agent name in the registration — refused (fix it: rustok connect $upd_client --force)" 1>&2
            upd_failed=$((upd_failed + 1))
            continue
        fi
        # A subshell on purpose: cmd_connect die()s on its own errors, and one
        # client's failure must not abort the others (summary + exit 1 below).
        if (CONNECT_TARGET="$upd_client" && AGENT="$upd_agent" && FORCE=1 && cmd_connect); then
            updated=$((updated + 1))
        else
            echo "rustok: $upd_client: re-registration FAILED — restore from the printed old entry if needed, or re-run: rustok connect $upd_client --force" 1>&2
            upd_failed=$((upd_failed + 1))
        fi
    done
    if [ "$updated" -eq 0 ] && [ "$upd_failed" -eq 0 ]; then
        echo "rustok: nothing to update — no rustok registration found (first: rustok connect claude|cursor|hermes)"
    else
        upd_tail=""
        [ "$upd_failed" -gt 0 ] && upd_tail=", $upd_failed FAILED"
        echo "rustok: updated $updated client(s)$upd_tail"
    fi
    echo "rustok: the shim itself does not self-update — re-run the installer (docs/INSTALL.md)"
    [ "$upd_failed" -eq 0 ] || exit 1
}

cmd_uninstall() {
    # Data-safe teardown, the install in reverse: registrations, containers,
    # secrets, PATH block, the shim itself. Keystore volumes = the keys =
    # the money: NEVER touched here — only by the doubly-gated purge below.
    for un_client in claude cursor hermes; do
        un_cfg="$(client_cfg_for "$un_client")"
        [ -f "$un_cfg" ] || continue
        case "$un_client" in
            claude)
                command -v jq >/dev/null 2>&1 || {
                    echo "rustok: warn: cannot probe $un_cfg without jq — if registered, remove it: claude mcp remove -s user rustok" 1>&2
                    continue
                }
                jq -e '.mcpServers.rustok' "$un_cfg" >/dev/null 2>&1 || continue
                if ! command -v claude >/dev/null 2>&1; then
                    echo "rustok: warn: claude CLI not found — remove the entry yourself: claude mcp remove -s user rustok" 1>&2
                elif claude mcp remove -s user rustok >/dev/null 2>&1; then
                    echo "rustok: deregistered from claude"
                else
                    echo "rustok: warn: 'claude mcp remove' failed — remove by hand: claude mcp remove -s user rustok" 1>&2
                fi
                ;;
            cursor)
                command -v jq >/dev/null 2>&1 || {
                    echo "rustok: warn: cannot edit $un_cfg without jq — remove .mcpServers.rustok by hand" 1>&2
                    continue
                }
                jq -e '.mcpServers.rustok' "$un_cfg" >/dev/null 2>&1 || continue
                un_tmp="$un_cfg.rustok-tmp"
                if jq 'del(.mcpServers.rustok)' <"$un_cfg" >"$un_tmp" 2>/dev/null \
                    && mv "$un_tmp" "$un_cfg"; then
                    echo "rustok: deregistered from cursor"
                else
                    rm -f "$un_tmp"
                    echo "rustok: warn: could not update $un_cfg — remove .mcpServers.rustok by hand" 1>&2
                fi
                ;;
            hermes)
                if ! command -v python3 >/dev/null 2>&1 || ! python3 -c 'import yaml' 2>/dev/null; then
                    echo "rustok: warn: cannot edit $un_cfg without python3+PyYAML — remove mcp_servers.rustok by hand" 1>&2
                    continue
                fi
                un_hrc=0
                python3 - "$un_cfg" >/dev/null 2>&1 <<'PYEOF' || un_hrc=$?
import sys
import yaml
try:
    cfg = yaml.safe_load(open(sys.argv[1]))
    if not isinstance(cfg, dict):
        raise ValueError("top level is not a mapping")
except Exception:
    sys.exit(3)
servers = cfg.get("mcp_servers")
sys.exit(0 if isinstance(servers, dict) and "rustok" in servers else 1)
PYEOF
                case "$un_hrc" in
                    1) continue ;;
                    3)
                        echo "rustok: warn: unreadable YAML in $un_cfg — remove mcp_servers.rustok by hand" 1>&2
                        continue
                        ;;
                esac
                un_bak="$un_cfg.rustok-bak-$(date +%Y%m%d-%H%M%S)"
                if ! cp "$un_cfg" "$un_bak" 2>/dev/null; then
                    echo "rustok: warn: cannot back up $un_cfg — left untouched; remove mcp_servers.rustok by hand" 1>&2
                    continue
                fi
                if python3 - "$un_cfg" <<'PYEOF'
import os
import sys
import tempfile
import yaml
cfg_path = sys.argv[1]
with open(cfg_path) as f:
    cfg = yaml.safe_load(f) or {}
servers = cfg.get("mcp_servers")
if isinstance(servers, dict):
    servers.pop("rustok", None)
fd, tmp = tempfile.mkstemp(
    dir=os.path.dirname(os.path.abspath(cfg_path)), prefix=".rustok-tmp-")
with os.fdopen(fd, "w") as f:
    yaml.safe_dump(cfg, f, sort_keys=False, allow_unicode=True)
os.replace(tmp, cfg_path)
PYEOF
                then
                    echo "rustok: deregistered from hermes (backup: $un_bak) — restart Hermes to pick it up"
                else
                    echo "rustok: warn: could not update $un_cfg — backup untouched at $un_bak" 1>&2
                fi
                ;;
        esac
    done
    ids="$(discover_ids "")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -gt 0 ]; then
        for un_id in "$@"; do
            "$engine" stop "$un_id" >/dev/null 2>&1 || true
        done
        echo "rustok: stopped $# running wallet(s)"
    fi
    if [ "$engine" = "podman" ]; then
        un_secrets="$("$engine" secret ls --format '{{.Name}}' 2>/dev/null | grep -E '^rustok-(keyring|rpc)-' || true)"
        un_n=0
        for un_s in $un_secrets; do
            "$engine" secret rm "$un_s" >/dev/null 2>&1 && un_n=$((un_n + 1))
        done
        [ "$un_n" -gt 0 ] && echo "rustok: removed $un_n secret(s)"
    else
        rm -f "$CONFIG_DIR"/keyring-pass-* 2>/dev/null || true
        echo "rustok: removed the stored password file(s)"
    fi
    # The 3.2 installer contract: its PATH edit lives between these exact
    # markers, and ONLY a fully marked block is ever removed — no marker,
    # no touching a shell profile.
    for un_prof in "$HOME/.bashrc" "$HOME/.zshrc" "$HOME/.profile"; do
        [ -f "$un_prof" ] || continue
        un_starts="$(grep -c '^# >>> rustok installer >>>$' "$un_prof")" || true
        un_ends="$(grep -c '^# <<< rustok installer <<<$' "$un_prof")" || true
        [ "$un_starts" = "0" ] && [ "$un_ends" = "0" ] && continue
        # EXACTLY one marker pair or hands off: sed range addressing does not
        # re-arm on a duplicated start marker — a twice-pasted block would
        # swallow unrelated user lines sitting between the two starts
        # (security pass 2.3c).
        if [ "$un_starts" != "1" ] || [ "$un_ends" != "1" ]; then
            echo "rustok: warn: $un_prof has $un_starts start/$un_ends end installer markers (expected exactly one pair) — left untouched, remove the block by hand" 1>&2
            continue
        fi
        un_tmp="$un_prof.rustok-tmp"
        if sed '/^# >>> rustok installer >>>$/,/^# <<< rustok installer <<<$/d' "$un_prof" >"$un_tmp" \
            && mv "$un_tmp" "$un_prof"; then
            echo "rustok: removed the installer PATH block from $un_prof"
        else
            rm -f "$un_tmp"
        fi
    done
    # Only the installed copy — a repo checkout being run in place stays.
    if [ -f "$HOME/.local/bin/rustok" ]; then
        rm -f "$HOME/.local/bin/rustok" && echo "rustok: removed ~/.local/bin/rustok"
    fi
    # Last: everything above still needed the engine pin.
    rm -rf "$CONFIG_DIR" 2>/dev/null || true
    # This regex is as WIDE as the whole namespace the shim could ever create
    # (per-agent `rustok-<name>` + the historical `rustok-wallet-tui`) — so an
    # unrelated `rustok-*` volume (e.g. a dev of this very repo) would land in
    # the list too. Mitigation (same prefix posture as the secret sweep): the
    # FULL list is printed before the literal confirmation below, so a human
    # sees every name before any deletion. Do not narrow blindly.
    un_vols="$("$engine" volume ls --format '{{.Name}}' 2>/dev/null | grep -E '^(rustok-wallet-tui|rustok-[A-Za-z0-9][A-Za-z0-9_-]*)$' || true)"
    if [ -z "$un_vols" ]; then
        echo "rustok: uninstall complete — no keystore volumes found"
        return 0
    fi
    if [ "$PURGE" -eq 0 ]; then
        echo "rustok: uninstall complete. keys intact: volume(s) $(printf '%s\n' "$un_vols" | tr '\n' ' ')— remove later: rustok uninstall --purge-keys"
        return 0
    fi
    # --- purge-keys: the ONE gated road to a keystore volume -------------------
    # Same Rule-of-two-windows gate as init: stdin must BE a terminal AND the
    # confirmation is read from /dev/tty itself. Honest contract (security
    # pass 2.3c): this stops pipes, blind -y automation and an agent invoking
    # rustok as a tool — it can NOT stop a process that allocates its own pty
    # (script(1), pty.spawn) or one with shell access, which needs no shim at
    # all to reach `podman volume rm` directly. The gate guards the shim's own
    # road; the engine itself is the platform's trust boundary.
    if [ ! -t 0 ]; then
        die "--purge-keys needs your own terminal — never run it through an agent or a pipe (it destroys keys)"
    fi
    if ! { exec 3</dev/tty; } 2>/dev/null; then
        die "--purge-keys needs your own terminal (no /dev/tty here) — it destroys keys"
    fi
    printf 'rustok: deleting these volumes destroys the keys; without your seed phrase backup the funds are unrecoverable:\n' >/dev/tty
    printf '%s\n' "$un_vols" | sed 's/^/  /' >/dev/tty
    printf "type 'delete my keys' to confirm: " >/dev/tty
    IFS= read -r un_confirm <&3 || un_confirm=""
    exec 3<&-
    [ "$un_confirm" = "delete my keys" ] || die "confirmation mismatch — volumes untouched"
    for un_v in $un_vols; do
        "$engine" volume rm -- "$un_v" >/dev/null \
            && echo "rustok: removed keystore volume '$un_v'"
    done
}

# --- entry -------------------------------------------------------------------

COMMAND="console"
AGENT=""
FORCE=0
PURGE=0
CONNECT_TARGET=""

if [ $# -gt 0 ]; then
    case "$1" in
        console | status | doctor | init | start | stop | update | uninstall)
            COMMAND="$1"
            shift
            ;;
        connect)
            COMMAND="connect"
            shift
            # the positional target names the agent CLIENT being registered
            # with; the wallet defaults to that client's own (--agent overrides)
            case "${1:-}" in
                claude | cursor | hermes)
                    CONNECT_TARGET="$1"
                    shift
                    ;;
                "" | -*)
                    echo "rustok: connect needs a target agent client: rustok connect claude|cursor|hermes" 1>&2
                    exit 2
                    ;;
                *)
                    echo "rustok: unknown connect target '$1' (supported: claude, cursor, hermes)" 1>&2
                    exit 2
                    ;;
            esac
            ;;
        help | --help | -h)
            usage
            exit 0
            ;;
        version | --version)
            echo "rustok $VERSION"
            exit 0
            ;;
        --agent) ;; # fall through to the option loop (command stays `console`)
        *)
            echo "rustok: unknown command '$1' (try: rustok help)" 1>&2
            exit 2
            ;;
    esac
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --agent)
            case "$COMMAND" in
                update | uninstall) die "--agent is not an update/uninstall flag — update follows each registration's own agent label; uninstall covers every agent" ;;
            esac
            [ $# -ge 2 ] || die "--agent needs a value (e.g. --agent claude)"
            # Strict charset (valid_agent_name — the ONE gate shared with the
            # label `update` reads back out of a client config): a name outside
            # it could inject flags/args into `podman run`, so it is a named
            # refusal here, once, for every command.
            valid_agent_name "$2" \
                || die "--agent name '$2' is invalid — use letters, digits, '-' or '_', starting with a letter or digit (e.g. claude, hermes)"
            AGENT="$2"
            shift 2
            ;;
        --force)
            case "$COMMAND" in
                init | connect) ;;
                *) die "--force is an init/connect-only flag" ;;
            esac
            FORCE=1
            shift
            ;;
        --purge-keys)
            case "$COMMAND" in
                uninstall) ;;
                *) die "--purge-keys is an uninstall-only flag" ;;
            esac
            PURGE=1
            shift
            ;;
        *)
            echo "rustok: unknown option '$1' (try: rustok help)" 1>&2
            exit 2
            ;;
    esac
done

resolve_engine

case "$COMMAND" in
    console) cmd_console ;;
    status) cmd_status ;;
    doctor) cmd_doctor ;;
    init) cmd_init ;;
    connect) cmd_connect ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
    update) cmd_update ;;
    uninstall) cmd_uninstall ;;
esac
