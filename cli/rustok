#!/bin/sh
# rustok ‚Äî the wallet's one command.
#
# Surface: `console` (default), `init`, `start`, `stop`, `status`, `doctor`,
# `help`, `version`. The wallet container is agent-launched and has NO fixed
# name (a fixed --name collides with health probes and a second `mcp list` ‚Äî
# the real production bug this shim exists to bury). Everything here discovers
# it by BOTH labels: `rustok=wallet` and `rustok.agent=<name>`.
#
# Security invariants (the trust boundary of init):
#   - the keyring password is read from /dev/tty only (Rule of two windows:
#     a pipe or an agent shell has no tty and gets a named refusal), travels
#     via a builtin printf into `podman secret create -` stdin or a 0600 file ‚Äî
#     NEVER through an engine argv, an env-file or a config;
#   - the seed + PIN print happens inside `create-wallet` on the INHERITED tty ‚Äî
#     the shim never captures, logs or re-echoes that output;
#   - `init` NEVER deletes a keystore volume; --force re-stores the SECRET only.
#
# POSIX sh on purpose (see epic decision #3): no arrays, no bashisms.
set -eu

VERSION="0.2.0"

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/rustok"
CONFIG_FILE="$CONFIG_DIR/config"
# The shipped wallet image; RUSTOK_IMAGE overrides (a digest-pinned ref comes
# with the installer stage of the epic).
DEFAULT_IMAGE="ghcr.io/rustok-org/rustok-wallet-tui:v0.7.1"

usage() {
    cat <<'EOF'
rustok ‚Äî self-custody wallet helper

Usage: rustok [command] [--agent <name>] [--force]

Commands:
  console        open the human approval console (default when no command);
                 starts the wallet first if an initialized one is not running
  init           create a NEW wallet for an agent (interactive; prints the
                 12-word phrase and approval PIN exactly once ‚Äî run it in your
                 own terminal, never through an agent)
  start          start the wallet container in the background
  stop           stop the running wallet container
  status         show the running wallet container(s)
  doctor         diagnose the setup (engine, config, PATH, leftovers)
  help           show this help
  version        show the shim version

Options:
  --agent <name>   the agent this wallet belongs to (default: claude)
  --force          init only: re-store the keyring password secret when it
                   already exists (the keystore volume is never touched)

Environment:
  RUSTOK_IMAGE       wallet image override
  RUSTOK_RPC_URLS_*  forwarded to `start` (never the keyring password). NOTE:
                     until `rustok connect` lands, a keyed RPC URL is passed by
                     name and is visible in `podman inspect` ‚Äî move provider
                     keys to a secret when connect is available.
EOF
}

die() {
    echo "rustok: $*" 1>&2
    exit 1
}

# --- engine ------------------------------------------------------------------
# Deterministic and STICKY (epic –ú-3): first resolution (podman preferred,
# docker fallback) is written to the config and never silently re-chosen ‚Äî
# wallet volumes live per-engine, so a quiet switch would "lose" the wallet.

resolve_engine() {
    engine=""
    if [ -f "$CONFIG_FILE" ]; then
        engine="$(sed -n 's/^engine=//p' "$CONFIG_FILE" | head -n 1)"
    fi
    if [ -n "$engine" ]; then
        case "$engine" in
            podman | docker) ;;
            *) die "configured engine '$engine' in $CONFIG_FILE is not podman or docker ‚Äî edit the config" ;;
        esac
        command -v "$engine" >/dev/null 2>&1 || die \
            "configured engine '$engine' ($CONFIG_FILE) is not installed ‚Äî reinstall it, or edit the config (a wallet volume does not move between engines)"
        return 0
    fi
    if command -v podman >/dev/null 2>&1; then
        engine="podman"
    elif command -v docker >/dev/null 2>&1; then
        engine="docker"
    else
        die "neither podman nor docker found ‚Äî install podman (recommended): https://podman.io/getting-started/installation"
    fi
    mkdir -p "$CONFIG_DIR"
    printf 'engine=%s\n' "$engine" >"$CONFIG_FILE"
}

# --- discovery ---------------------------------------------------------------
# ALWAYS both labels. `--filter label=rustok=wallet` alone would match another
# agent's wallet; `rustok.agent` alone would match a non-wallet container.

discover_ids() {
    # $1: agent name or "" for any agent. An installed-but-dead engine must be
    # a named error here too, not a raw `ps` stderr (doctor already says it
    # nicely ‚Äî console/status deserve the same).
    if [ -n "$1" ]; then
        "$engine" ps -q --filter label=rustok=wallet --filter "label=rustok.agent=$1" \
            || die "'$engine' failed listing containers ‚Äî is the service running? (try: rustok doctor)"
    else
        "$engine" ps -q --filter label=rustok=wallet \
            || die "'$engine' failed listing containers ‚Äî is the service running? (try: rustok doctor)"
    fi
}

agent_of() {
    # `inspect ‚Ä¶ index .Config.Labels` is the one label accessor both engines
    # implement identically (ps --format templates differ between them).
    # Pre-label wallets (older launch configs) carry no rustok.agent at all ‚Äî
    # they are real and must show up readably, not as an empty string.
    name="$("$engine" inspect --format '{{ index .Config.Labels "rustok.agent" }}' "$1" 2>/dev/null || true)"
    if [ -n "$name" ]; then
        printf '%s\n' "$name"
    else
        echo "(unlabeled)"
    fi
}

agent_list() {
    # Sorted, comma-separated agent names of every running wallet ‚Äî the loud
    # N>1 refusal must NAME the choices, never pick the first match.
    # (awk, not `paste -d ', '`: paste CYCLES multi-char delimiter lists.)
    for id in "$@"; do
        agent_of "$id"
    done | LC_ALL=C sort | awk 'NR > 1 { printf ", " } { printf "%s", $0 } END { print "" }'
}

# --- per-agent naming ----------------------------------------------------------

volume_for() {
    # claude keeps the historical volume name every doc and existing user has;
    # any other agent gets its own per-agent volume (epic decision #4).
    if [ "$1" = "claude" ]; then
        echo "rustok-wallet-tui"
    else
        echo "rustok-$1"
    fi
}

secret_for() { echo "rustok-keyring-$1"; }
password_file_for() { echo "$CONFIG_DIR/keyring-pass-$1"; }

image_ref() { echo "${RUSTOK_IMAGE:-$DEFAULT_IMAGE}"; }

secret_present() {
    # podman: the secret store; docker (no store without swarm): the 0600 file.
    if [ "$engine" = "podman" ]; then
        "$engine" secret exists "$(secret_for "$1")"
    else
        [ -f "$(password_file_for "$1")" ]
    fi
}

password_args_for() {
    # The engine-run fragment delivering the password ‚Äî value never in argv.
    if [ "$engine" = "podman" ]; then
        echo "--secret $(secret_for "$1"),type=env,target=RUSTOK_KEYRING_PASSWORD"
    else
        echo "-v $(password_file_for "$1"):/run/keyring-pass:ro -e RUSTOK_KEYRING_PASSWORD_FILE=/run/keyring-pass"
    fi
}

rustok_env_names() {
    # RUSTOK_* config vars forwarded to `start` BY NAME (`-e NAME` inherits the
    # value engine-side ‚Äî values stay out of argv AND out of shell history).
    # The keyring password is deliberately excluded: it travels only as a
    # secret/_FILE, and a stray env var would win over the stored secret and
    # cause mismatched-unlock mysteries. RUSTOK_IMAGE is the shim's own knob.
    #
    # INTERIM (epic escalation #2): a keyed RPC URL is a second-class secret and
    # the epic ratified delivering it as a podman `--secret rustok-rpc-<agent>`.
    # That secret is created by `connect` (PR-2.3a), which does not exist yet, so
    # `start` forwards RUSTOK_RPC_URLS_* by name for now ‚Äî the value is out of
    # argv/history but visible in `podman inspect Config.Env`. PR-2.3a moves it to
    # a secret. Not fund/seed exposure (same-user inspect); documented, not silent.
    env | sed -n 's/^\(RUSTOK_[A-Z0-9_]*\)=.*/\1/p' \
        | grep -v -E '^RUSTOK_(KEYRING_PASSWORD(_FILE)?|IMAGE)$' || true
}

# --- commands ----------------------------------------------------------------

read_password_twice() {
    # The gate: stdin must BE a terminal (a pipe or an agent shell fails
    # `-t 0` deterministically ‚Äî some agent sandboxes still carry a readable
    # /dev/tty, so probing /dev/tty alone is not a reliable refusal). Then the
    # password is read from /dev/tty itself, immune to later redirections
    # (Rule of two windows).
    if [ ! -t 0 ]; then
        die "init needs your own terminal ‚Äî never run it through an agent or a pipe: the recovery phrase would leak into its context"
    fi
    if ! { exec 3</dev/tty; } 2>/dev/null; then
        die "init needs your own terminal (no /dev/tty here) ‚Äî never run it through an agent or a pipe: the recovery phrase would leak into its context"
    fi
    # Restore echo (and drop the password) on Ctrl-C / kill during entry ‚Äî
    # otherwise the terminal is left with echo off.
    trap 'stty echo </dev/tty 2>/dev/null || true; PW="" PW2=""; exit 130' INT TERM HUP
    printf 'Keyring password (unlocks the keystore): ' >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    IFS= read -r PW <&3 || PW=""
    stty echo </dev/tty 2>/dev/null || true
    printf '\n' >/dev/tty
    printf 'Repeat the password: ' >/dev/tty
    stty -echo </dev/tty 2>/dev/null || true
    IFS= read -r PW2 <&3 || PW2=""
    stty echo </dev/tty 2>/dev/null || true
    printf '\n' >/dev/tty
    trap - INT TERM HUP
    exec 3<&-
    [ -n "$PW" ] || die "empty password ‚Äî nothing stored"
    [ "$PW" = "$PW2" ] || die "passwords do not match ‚Äî nothing stored"
}

store_password() {
    # printf is a shell BUILTIN in every /bin/sh we target (dash/bash/ash):
    # the password never becomes a process argv.
    if [ "$engine" = "podman" ]; then
        printf '%s' "$PW" | "$engine" secret create "$(secret_for "$1")" - >/dev/null
    else
        umask 077
        mkdir -p "$CONFIG_DIR"
        printf '%s' "$PW" >"$(password_file_for "$1")"
    fi
}

remove_stored_password() {
    if [ "$engine" = "podman" ]; then
        "$engine" secret rm "$(secret_for "$1")" >/dev/null
    else
        rm -f "$(password_file_for "$1")"
    fi
}

cmd_init() {
    agent="${AGENT:-claude}"
    volume="$(volume_for "$agent")"

    volume_exists=0
    "$engine" volume exists "$volume" 2>/dev/null && volume_exists=1

    if [ "$volume_exists" -eq 1 ] && [ "$FORCE" -eq 0 ]; then
        die "wallet volume '$volume' already exists ‚Äî init creates NEW wallets and never touches keystores. To re-store a changed keyring password: rustok init --force (secret only; your keys stay put)"
    fi
    if secret_present "$agent" && [ "$FORCE" -eq 0 ]; then
        die "a stored keyring password for agent '$agent' already exists ‚Äî rerun with --force to replace it (the keystore volume is never touched)"
    fi

    read_password_twice
    if secret_present "$agent"; then
        remove_stored_password "$agent"
    fi
    store_password "$agent"
    PW="" PW2=""
    echo "rustok: keyring password stored for agent '$agent' ($engine)"

    if [ "$volume_exists" -eq 1 ]; then
        echo "rustok: keystore volume '$volume' already present ‚Äî password re-stored, wallet untouched"
        return 0
    fi

    # Onboarding prints the 12 words + PIN ONCE, on the inherited tty ‚Äî the
    # shim adds no capture, no tee, no log around it.
    echo "rustok: creating the wallet ‚Äî back up the 12 words and the PIN it prints:"
    # shellcheck disable=SC2046  # password_args_for emits a word-split fragment
    "$engine" run -it --rm \
        -v "$volume:/data" \
        $(password_args_for "$agent") \
        "$(image_ref)" create-wallet
    echo "rustok: wallet created for agent '$agent' ‚Äî next: rustok start (or connect your agent), then fund the address"
}

wallet_run_args() {
    # The detached labeled run ‚Äî shared by `start` and console auto-start.
    # NEVER --name: labels only (that is the whole point of the label model).
    agent="$1"
    volume="$(volume_for "$agent")"
    set -- run -d -i --rm --init \
        --label rustok=wallet --label "rustok.agent=$agent" \
        -v "$volume:/data"
    for name in $(rustok_env_names); do
        set -- "$@" -e "$name"
    done
    # shellcheck disable=SC2046
    set -- "$@" $(password_args_for "$agent") "$(image_ref)"
    printf '%s\n' "$@"
}

start_wallet_detached() {
    agent="$1"
    secret_present "$agent" || die "no stored keyring password for agent '$agent' ‚Äî run: rustok init"
    "$engine" volume exists "$(volume_for "$agent")" 2>/dev/null \
        || die "no wallet volume '$(volume_for "$agent")' ‚Äî run: rustok init"
    # Rebuild argv from the newline list (values never contain newlines here:
    # names/labels/volumes are ours, the password rides the secret store).
    set --
    while IFS= read -r arg; do
        set -- "$@" "$arg"
    done <<EOF
$(wallet_run_args "$agent")
EOF
    "$engine" "$@" >/dev/null
    echo "rustok: wallet for agent '$agent' starting in the background"
}

cmd_start() {
    agent="${AGENT:-claude}"
    ids="$(discover_ids "$agent")"
    if [ -n "$ids" ]; then
        die "wallet for agent '$agent' is already running (see: rustok status)"
    fi
    start_wallet_detached "$agent"
}

cmd_stop() {
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086
    set -- $ids
    case $# in
        0)
            echo "rustok: nothing to stop"
            ;;
        1)
            "$engine" stop "$1" >/dev/null
            echo "rustok: wallet stopped"
            ;;
        *)
            die "multiple wallets running: $(agent_list "$@") ‚Äî use --agent <name>"
            ;;
    esac
}

cmd_console() {
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086  # word-splitting the id list is the point
    set -- $ids
    case $# in
        0)
            # exec-or-start (epic pain #6): an initialized wallet is started
            # here and now; an uninitialized one gets pointed at init.
            agent="${AGENT:-claude}"
            if ! secret_present "$agent" 2>/dev/null; then
                if [ -n "$AGENT" ]; then
                    die "no wallet running for agent '$AGENT' ‚Äî start that agent's session first (check: rustok status)"
                fi
                die "no wallet running ‚Äî the agent session starts it; check: rustok status (new here? rustok init)"
            fi
            start_wallet_detached "$agent"
            # The console needs the approver socket, which core creates during
            # startup ‚Äî poll briefly instead of failing into a raw error.
            tries=0
            while ! "$engine" exec "$(discover_ids "$agent")" test -S /run/wallet/approve.sock 2>/dev/null; do
                tries=$((tries + 1))
                [ "$tries" -gt 30 ] && die "wallet started but the approval socket never appeared ‚Äî check: rustok status / $engine logs"
                sleep 1
            done
            exec "$engine" exec -it "$(discover_ids "$agent")" rustok-console
            ;;
        1)
            exec "$engine" exec -it "$1" rustok-console
            ;;
        *)
            list="$(agent_list "$@")"
            echo "rustok: multiple wallets running: $list ‚Äî use --agent <name>" 1>&2
            case "$list" in
                *"(unlabeled)"*)
                    echo "rustok: hint: an '(unlabeled)' wallet predates the label model ‚Äî add --label rustok.agent=<name> to its launch config (see docs/INSTALL.md)" 1>&2
                    ;;
            esac
            exit 1
            ;;
    esac
}

cmd_status() {
    echo "engine: $engine ($CONFIG_FILE)"
    ids="$(discover_ids "$AGENT")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -eq 0 ]; then
        echo "no wallet running ‚Äî the agent session starts it"
        return 0
    fi
    printf '%-12s %-14s %s\n' "AGENT" "CONTAINER" "IMAGE"
    for id in "$@"; do
        image="$("$engine" inspect --format '{{.Config.Image}}' "$id" 2>/dev/null || echo '?')"
        printf '%-12s %-14s %s\n' "$(agent_of "$id")" "$(printf '%.12s' "$id")" "$image"
    done
}

cmd_doctor() {
    failed=0
    # resolve_engine has already pinned the choice by the time we are here.
    echo "ok: engine '$engine' (pinned in $CONFIG_FILE)"
    if ! "$engine" info >/dev/null 2>&1; then
        echo "fail: '$engine' is installed but not usable ‚Äî is the service/machine running?"
        failed=1
    else
        echo "ok: $engine is responding"
    fi
    # PATH sanity for the shim install dir.
    case ":$PATH:" in
        *":$HOME/.local/bin:"*) echo "ok: ~/.local/bin is on PATH" ;;
        *) echo "warn: ~/.local/bin is NOT on PATH ‚Äî the installer puts rustok there; add it to your shell profile" ;;
    esac
    # Running wallets.
    ids="$(discover_ids "")"
    # shellcheck disable=SC2086
    set -- $ids
    if [ $# -eq 0 ]; then
        echo "info: no wallet running (the agent session starts it)"
    else
        echo "ok: $# wallet(s) running: $(agent_list "$@")"
        unlabeled=0
        for id in "$@"; do
            if [ "$(agent_of "$id")" = "(unlabeled)" ]; then
                unlabeled=$((unlabeled + 1))
            fi
        done
        if [ "$unlabeled" -gt 0 ]; then
            echo "warn: $unlabeled wallet(s) without a rustok.agent label (pre-label config) ‚Äî add --label rustok.agent=<name> (see docs/INSTALL.md)"
        fi
    fi
    # The legacy fixed-name container the label model replaced.
    legacy="$("$engine" ps -aq --filter name=rustok-wallet-tui 2>/dev/null || true)"
    if [ -n "$legacy" ]; then
        echo "warn: leftover fixed-name container 'rustok-wallet-tui' from an old setup ‚Äî remove it: $engine rm -f rustok-wallet-tui"
    fi
    return "$failed"
}

# --- entry -------------------------------------------------------------------

COMMAND="console"
AGENT=""
FORCE=0

if [ $# -gt 0 ]; then
    case "$1" in
        console | status | doctor | init | start | stop)
            COMMAND="$1"
            shift
            ;;
        help | --help | -h)
            usage
            exit 0
            ;;
        version | --version)
            echo "rustok $VERSION"
            exit 0
            ;;
        --agent) ;; # fall through to the option loop (command stays `console`)
        *)
            echo "rustok: unknown command '$1' (try: rustok help)" 1>&2
            exit 2
            ;;
    esac
fi

while [ $# -gt 0 ]; do
    case "$1" in
        --agent)
            [ $# -ge 2 ] || die "--agent needs a value (e.g. --agent claude)"
            # Strict charset: the agent name becomes a container label, a volume
            # name and (unquoted) a run-argv token. Anything outside this set ‚Äî
            # spaces, newlines, a leading dash, shell metacharacters ‚Äî could
            # inject flags/args into `podman run`, so it is a named refusal here,
            # once, for every command. (Threat model: pasted untrusted commands.)
            case "$2" in
                [a-zA-Z0-9]*[!a-zA-Z0-9_-]* | [!a-zA-Z0-9]* | "") \
                    die "--agent name '$2' is invalid ‚Äî use letters, digits, '-' or '_', starting with a letter or digit (e.g. claude, hermes)" ;;
            esac
            AGENT="$2"
            shift 2
            ;;
        --force)
            [ "$COMMAND" = "init" ] || die "--force is an init-only flag"
            FORCE=1
            shift
            ;;
        *)
            echo "rustok: unknown option '$1' (try: rustok help)" 1>&2
            exit 2
            ;;
    esac
done

resolve_engine

case "$COMMAND" in
    console) cmd_console ;;
    status) cmd_status ;;
    doctor) cmd_doctor ;;
    init) cmd_init ;;
    start) cmd_start ;;
    stop) cmd_stop ;;
esac
