# Rustok MCP server environment. Copy to .env (chmod 600) and fill in.
# Placeholders only — never commit a real .env.

# Bind address / port. In containers MCP binds 0.0.0.0; host publishing and
# public exposure are controlled by the compose profile in rustok-org/meta.
RUSTOK_MCP_HOST=127.0.0.1
RUSTOK_MCP_PORT=3001

# Gateway base URL MCP forwards wallet calls to.
RUSTOK_MCP_GATEWAY_URL=http://127.0.0.1:3000

# Outbound key MCP presents to the Gateway (Authorization: Bearer). Optional in
# dev; when empty, Gateway auth is disabled.
RUSTOK_MCP_API_KEY=

# Inbound key clients must present to MCP's SSE transport (Authorization:
# Bearer). Leave empty for the loopback dev flow. REQUIRED before exposing MCP
# publicly. Generate a high-entropy value:
#   openssl rand -hex 32
RUSTOK_MCP_INBOUND_API_KEY=

# Capabilities granted to the stdio agent (read_wallet,preview_tx,execute_tx).
# Empty/unset → all (stdio is process-trusted). Set a subset for a restricted
# agent, e.g. RUSTOK_MCP_CAPABILITIES=read_wallet for a read-only wallet.
RUSTOK_MCP_CAPABILITIES=

# Log level (DEBUG / INFO / WARNING / ERROR).
RUSTOK_MCP_LOG_LEVEL=INFO
